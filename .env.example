# VeriDocs SDK — Environment Configuration

# REQUIRED: 32-byte hex secret for encrypted key storage
SECRET_KEY=29739248cad1bd1a0fc4d9b75cd4d2990de535baf5caadfdf8d8f86664aa830c

# Set after running: POST /api/setup/org or docker compose exec sdk node create-did.js
ORG_DID=

# Central VeriDocs Register URL
REGISTRY_URL=http://localhost:8001
REGISTRY_EMAIL=
REGISTRY_PASSWORD=
REGISTRY_API_KEY=
REGISTRY_DOMAIN=localhost%3A8001

# Signing mode: 'local' (own keys) or 'delegate' (Registry signs)
SIGNING_MODE=local

# For delegate mode: URL and API key of the Registry's Veramo agent
DELEGATE_URL=
DELEGATE_API_KEY=

# API key for SDK endpoints (optional; leave empty to disable auth)
VERAMO_API_KEY=

# SDK port
SDK_PORT=3100
VC_HOST_BASE=http://localhost:3100
CONTEXT_ORIGIN=http://localhost:3100

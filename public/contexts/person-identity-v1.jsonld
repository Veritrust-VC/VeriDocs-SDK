{
  "@context": {
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",

    "PersonIdentityCredential": "https://veritrust.vc/terms#PersonIdentityCredential",
    "identityVerification": "https://veritrust.vc/terms#identityVerification",
    "KYCVerification": "https://veritrust.vc/terms#KYCVerification",

    "verifiedAttributes": {
      "@id": "https://veritrust.vc/terms#verifiedAttributes",
      "@container": "@set"
    },
    "verificationMethod": "https://veritrust.vc/terms#verificationMethod",
    "verificationDate": {
      "@id": "https://veritrust.vc/terms#verificationDate",
      "@type": "xsd:date"
    },
    "compliance": {
      "@id": "https://veritrust.vc/terms#compliance",
      "@container": "@set"
    }
  }
}
